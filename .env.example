# App Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/hello_oman_sheba?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=hello_oman_sheba

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Authentication
AUTH_SECRET=your-super-secret-auth-key-change-this-in-production
AUTH_URL=http://localhost:3000

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Email
EMAIL_FROM=noreply@helloomansheba.com
RESEND_API_KEY=
SENDGRID_API_KEY=

# SMS & WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Push Notifications
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Storage (Cloudflare R2 / AWS S3)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKET_NAME=
CLOUDFLARE_PUBLIC_URL=

# Alternative: AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# Search (Meilisearch)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Payment Gateways
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false

# Future: Oman Payment Gateway
THAWANI_PUBLIC_KEY=
THAWANI_SECRET_KEY=
OMANNET_MERCHANT_ID=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_ID=

# Monitoring
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
LOGR OCKET_APP_ID=

# Socket.io
SOCKET_IO_PORT=3001
SOCKET_IO_SECRET=your-socket-secret

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# AI Features (Future)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Localization
NEXT_PUBLIC_DEFAULT_LOCALE=bn
NEXT_PUBLIC_SUPPORTED_LOCALES=bn,en,ar

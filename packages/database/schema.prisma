// Prisma Schema for Hello Oman Sheba
// Enterprise Digital Service Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTHENTICATION & USER MANAGEMENT
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  phone         String?   @unique
  phoneVerified Boolean   @default(false)
  password      String?
  name          String
  nameBn        String? // Bengali name
  avatar        String?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  
  // Profile Information
  dateOfBirth   DateTime?
  gender        Gender?
  nationality   String?   @default("Bangladesh")
  passportNo    String?
  omanId        String?
  
  // Location
  city          String?
  area          String?
  
  // Preferences
  language      String    @default("bn")
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  jobApplications JobApplication[]
  savedJobs     SavedJob[]
  properties    Property[]
  vehicles      Vehicle[]
  reviews       Review[]
  messages      Message[]
  notifications Notification[]
  favorites     Favorite[]
  bookings      Booking[]
  forumPosts    ForumPost[]
  forumComments ForumComment[]
  classifieds   Classified[]
  
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("users")
}

enum UserRole {
  USER
  SERVICE_PROVIDER
  RECRUITER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// JOB PORTAL MODULE
// ==========================================

model Job {
  id              String      @id @default(cuid())
  title           String
  titleBn         String
  slug            String      @unique
  description     String      @db.Text
  descriptionBn   String      @db.Text
  
  // Company Information
  company         Company     @relation(fields: [companyId], references: [id])
  companyId       String
  
  // Job Details
  category        JobCategory @relation(fields: [categoryId], references: [id])
  categoryId      String
  type            JobType
  experience      String // "0-2 years", "3-5 years"
  education       String
  vacancy         Int         @default(1)
  
  // Location
  city            String
  area            String?
  
  // Salary
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String      @default("BDT")
  salaryPeriod    String      @default("MONTHLY") // MONTHLY, YEARLY
  
  // Requirements
  skills          String[]
  benefits        String[]
  
  // Application
  applicationDeadline DateTime?
  applicationEmail    String?
  applicationPhone    String?
  applicationUrl      String?
  
  // Status & Visibility
  status          JobStatus   @default(DRAFT)
  featured        Boolean     @default(false)
  views           Int         @default(0)
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  publishedAt     DateTime?
  expiresAt       DateTime?
  
  // Relations
  applications    JobApplication[]
  savedBy         SavedJob[]
  
  @@index([slug])
  @@index([companyId])
  @@index([categoryId])
  @@index([status])
  @@index([city])
  @@index([type])
  @@map("jobs")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  EXPIRED
}

model JobCategory {
  id          String   @id @default(cuid())
  name        String
  nameBn      String
  slug        String   @unique
  icon        String?
  description String?
  parentId    String?
  parent      JobCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    JobCategory[] @relation("CategoryHierarchy")
  jobs        Job[]
  order       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([slug])
  @@map("job_categories")
}

model Company {
  id              String   @id @default(cuid())
  name            String
  nameBn          String?
  slug            String   @unique
  logo            String?
  cover           String?
  description     String?  @db.Text
  descriptionBn   String?  @db.Text
  
  // Contact
  email           String?
  phone           String?
  website         String?
  
  // Location
  address         String?
  city            String?
  country         String   @default("Oman")
  
  // Social
  facebook        String?
  twitter         String?
  linkedin        String?
  instagram       String?
  
  // Verification
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  
  // Statistics
  employeeCount   String? // "10-50", "50-200"
  foundedYear     Int?
  industry        String?
  
  // Status
  status          ServiceProviderStatus @default(PENDING)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  jobs            Job[]
  reviews         Review[]
  
  @@index([slug])
  @@index([verified])
  @@index([status])
  @@map("companies")
}

model JobApplication {
  id          String              @id @default(cuid())
  job         Job                 @relation(fields: [jobId], references: [id])
  jobId       String
  user        User                @relation(fields: [userId], references: [id])
  userId      String
  
  // Application Data
  coverLetter String?             @db.Text
  cvUrl       String
  status      ApplicationStatus   @default(PENDING)
  
  // Tracking
  viewedAt    DateTime?
  respondedAt DateTime?
  notes       String?             @db.Text
  
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
  @@map("job_applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  INTERVIEWED
  OFFERED
  ACCEPTED
  REJECTED
}

model SavedJob {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  job       Job      @relation(fields: [jobId], references: [id])
  jobId     String
  createdAt DateTime @default(now())
  
  @@unique([userId, jobId])
  @@index([userId])
  @@map("saved_jobs")
}

// ==========================================
// PROPERTY MODULE
// ==========================================

model Property {
  id              String        @id @default(cuid())
  title           String
  titleBn         String
  slug            String        @unique
  description     String        @db.Text
  descriptionBn   String        @db.Text
  
  // Type & Category
  type            PropertyType
  category        PropertyCategory
  purpose         PropertyPurpose
  
  // Location
  city            String
  area            String
  address         String?
  latitude        Float?
  longitude       Float?
  
  // Details
  bedrooms        Int?
  bathrooms       Int?
  size            Float? // sqft or sqm
  sizeUnit        String?        @default("sqft")
  floor           Int?
  totalFloors     Int?
  furnished       FurnishedStatus?
  
  // Price
  price           Float
  currency        String         @default("BDT")
  priceNegotiable Boolean        @default(false)
  
  // Amenities
  amenities       String[]
  
  // Media
  images          String[]
  videos          String[]
  virtualTour     String?
  
  // Contact
  contactName     String
  contactPhone    String
  contactEmail    String?
  contactWhatsapp String?
  
  // Availability
  availableFrom   DateTime?
  
  // Owner
  owner           User           @relation(fields: [ownerId], references: [id])
  ownerId         String
  
  // Status & Visibility
  status          ListingStatus  @default(DRAFT)
  featured        Boolean        @default(false)
  verified        Boolean        @default(false)
  views           Int            @default(0)
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  publishedAt     DateTime?
  expiresAt       DateTime?
  
  // Relations
  favorites       Favorite[]
  
  @@index([slug])
  @@index([ownerId])
  @@index([type])
  @@index([category])
  @@index([purpose])
  @@index([city])
  @@index([status])
  @@map("properties")
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
}

enum PropertyCategory {
  HOUSE
  FLAT
  APARTMENT
  VILLA
  ROOM
  BED_SPACE
  OFFICE
  SHOP
  WAREHOUSE
  SHOWROOM
  LAND
  BUILDING
}

enum PropertyPurpose {
  RENT
  SALE
  BOTH
}

enum FurnishedStatus {
  FURNISHED
  SEMI_FURNISHED
  UNFURNISHED
}

// ==========================================
// VEHICLE MODULE
// ==========================================

model Vehicle {
  id              String          @id @default(cuid())
  title           String
  titleBn         String
  slug            String          @unique
  description     String          @db.Text
  descriptionBn   String          @db.Text
  
  // Vehicle Details
  type            VehicleType
  make            String // Toyota, Nissan, etc.
  model           String
  year            Int
  color           String?
  mileage         Int? // in KM
  condition       VehicleCondition
  transmission    TransmissionType
  fuelType        FuelType
  
  // Specifications
  engineCapacity  String? // "2.0L"
  seats           Int?
  doors           Int?
  
  // Documents
  registrationNo  String?
  chassisNo       String?
  insurance       Boolean         @default(false)
  insuranceExpiry DateTime?
  
  // Price & Purpose
  purpose         VehiclePurpose
  price           Float?
  currency        String          @default("BDT")
  priceNegotiable Boolean         @default(false)
  
  // Rental (if applicable)
  rentPerDay      Float?
  rentPerMonth    Float?
  
  // Media
  images          String[]
  
  // Location
  city            String
  area            String?
  
  // Contact
  contactName     String
  contactPhone    String
  contactWhatsapp String?
  
  // Owner
  owner           User            @relation(fields: [ownerId], references: [id])
  ownerId         String
  
  // Status & Visibility
  status          ListingStatus   @default(DRAFT)
  featured        Boolean         @default(false)
  verified        Boolean         @default(false)
  sold            Boolean         @default(false)
  views           Int             @default(0)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  publishedAt     DateTime?
  expiresAt       DateTime?
  
  @@index([slug])
  @@index([ownerId])
  @@index([type])
  @@index([purpose])
  @@index([city])
  @@index([status])
  @@map("vehicles")
}

enum VehicleType {
  CAR
  MOTORCYCLE
  TRUCK
  VAN
  BUS
  BICYCLE
  OTHER
}

enum VehicleCondition {
  NEW
  USED_LIKE_NEW
  USED_GOOD
  USED_FAIR
  NEEDS_REPAIR
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  CNG
}

enum VehiclePurpose {
  SALE
  RENT
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  SOLD
  REMOVED
}

// ==========================================
// SERVICE PROVIDERS MODULE
// ==========================================

model ServiceProvider {
  id              String                  @id @default(cuid())
  name            String
  nameBn          String
  slug            String                  @unique
  logo            String?
  cover           String?
  description     String?                 @db.Text
  descriptionBn   String?                 @db.Text
  
  // Category
  category        ServiceCategory         @relation(fields: [categoryId], references: [id])
  categoryId      String
  
  // Contact
  email           String?
  phone           String
  whatsapp        String?
  website         String?
  
  // Location
  address         String?
  city            String
  area            String?
  latitude        Float?
  longitude       Float?
  
  // Business Info
  licenseNo       String?
  crNo            String? // Commercial Registration
  
  // Availability
  businessHours   Json? // { "monday": {"open": "09:00", "close": "18:00"} }
  
  // Services Offered
  services        String[]
  
  // Media
  images          String[]
  videos          String[]
  
  // Social
  facebook        String?
  instagram       String?
  twitter         String?
  
  // Verification & Status
  verified        Boolean                 @default(false)
  verifiedAt      DateTime?
  status          ServiceProviderStatus   @default(PENDING)
  
  // Statistics
  rating          Float?                  @default(0)
  reviewCount     Int                     @default(0)
  views           Int                     @default(0)
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Timestamps
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  
  // Relations
  reviews         Review[]
  bookings        Booking[]
  
  @@index([slug])
  @@index([categoryId])
  @@index([city])
  @@index([verified])
  @@index([status])
  @@map("service_providers")
}

enum ServiceProviderStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model ServiceCategory {
  id              String            @id @default(cuid())
  name            String
  nameBn          String
  slug            String            @unique
  icon            String?
  description     String?
  parentId        String?
  parent          ServiceCategory?  @relation("ServiceCategoryHierarchy", fields: [parentId], references: [id])
  children        ServiceCategory[] @relation("ServiceCategoryHierarchy")
  providers       ServiceProvider[]
  order           Int               @default(0)
  featured        Boolean           @default(false)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([slug])
  @@map("service_categories")
}

// ==========================================
// REVIEWS & RATINGS
// ==========================================

model Review {
  id              String          @id @default(cuid())
  rating          Int // 1-5
  comment         String?         @db.Text
  
  // Reviewable (Polymorphic)
  reviewableType  String // "Company", "ServiceProvider", etc.
  reviewableId    String
  
  // Author
  user            User            @relation(fields: [userId], references: [id])
  userId          String
  
  // Relations (optional, for specific types)
  company         Company?        @relation(fields: [companyId], references: [id])
  companyId       String?
  serviceProvider ServiceProvider? @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String?
  
  // Status
  status          ReviewStatus    @default(PENDING)
  helpful         Int             @default(0)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([userId])
  @@index([reviewableType, reviewableId])
  @@index([status])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

// ==========================================
// FAVORITES & BOOKINGS
// ==========================================

model Favorite {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  
  // Favoritable (Polymorphic)
  favoriteType  String // "Job", "Property", "Vehicle", "ServiceProvider"
  favoriteId    String
  
  // Relations (optional)
  property      Property? @relation(fields: [propertyId], references: [id])
  propertyId    String?
  
  createdAt     DateTime @default(now())
  
  @@unique([userId, favoriteType, favoriteId])
  @@index([userId])
  @@map("favorites")
}

model Booking {
  id                String          @id @default(cuid())
  user              User            @relation(fields: [userId], references: [id])
  userId            String
  serviceProvider   ServiceProvider @relation(fields: [serviceProviderId], references: [id])
  serviceProviderId String
  
  // Booking Details
  serviceType       String
  date              DateTime
  time              String?
  notes             String?         @db.Text
  
  // Status
  status            BookingStatus   @default(PENDING)
  
  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  confirmedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  
  @@index([userId])
  @@index([serviceProviderId])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ==========================================
// MESSAGING SYSTEM
// ==========================================

model Message {
  id          String        @id @default(cuid())
  content     String        @db.Text
  sender      User          @relation(fields: [senderId], references: [id])
  senderId    String
  
  // Thread/Conversation
  threadId    String
  
  // Status
  read        Boolean       @default(false)
  readAt      DateTime?
  
  // Attachments
  attachments String[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([senderId])
  @@index([threadId])
  @@map("messages")
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id          String             @id @default(cuid())
  user        User               @relation(fields: [userId], references: [id])
  userId      String
  
  type        NotificationType
  title       String
  titleBn     String?
  message     String             @db.Text
  messageBn   String?            @db.Text
  
  // Link/Action
  link        String?
  actionType  String?
  actionId    String?
  
  // Status
  read        Boolean            @default(false)
  readAt      DateTime?
  
  createdAt   DateTime           @default(now())
  
  @@index([userId])
  @@index([read])
  @@map("notifications")
}

enum NotificationType {
  JOB_APPLICATION
  JOB_ALERT
  MESSAGE
  BOOKING
  REVIEW
  SYSTEM
  ANNOUNCEMENT
}

// ==========================================
// COMMUNITY FORUM
// ==========================================

model ForumPost {
  id            String         @id @default(cuid())
  title         String
  titleBn       String?
  slug          String         @unique
  content       String         @db.Text
  contentBn     String?        @db.Text
  
  // Author
  author        User           @relation(fields: [authorId], references: [id])
  authorId      String
  
  // Category
  category      ForumCategory  @relation(fields: [categoryId], references: [id])
  categoryId    String
  
  // Tags
  tags          String[]
  
  // Status
  status        PostStatus     @default(PUBLISHED)
  pinned        Boolean        @default(false)
  locked        Boolean        @default(false)
  
  // Statistics
  views         Int            @default(0)
  likes         Int            @default(0)
  
  // Timestamps
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  // Relations
  comments      ForumComment[]
  
  @@index([slug])
  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@map("forum_posts")
}

model ForumComment {
  id          String     @id @default(cuid())
  content     String     @db.Text
  
  // Author
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  
  // Post
  post        ForumPost  @relation(fields: [postId], references: [id])
  postId      String
  
  // Parent Comment (for replies)
  parentId    String?
  parent      ForumComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     ForumComment[] @relation("CommentReplies")
  
  // Status
  status      PostStatus @default(PUBLISHED)
  likes       Int        @default(0)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([authorId])
  @@index([postId])
  @@map("forum_comments")
}

model ForumCategory {
  id          String      @id @default(cuid())
  name        String
  nameBn      String
  slug        String      @unique
  description String?
  icon        String?
  order       Int         @default(0)
  
  posts       ForumPost[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([slug])
  @@map("forum_categories")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
  DELETED
}

// ==========================================
// CLASSIFIEDS
// ==========================================

model Classified {
  id              String            @id @default(cuid())
  title           String
  titleBn         String
  slug            String            @unique
  description     String            @db.Text
  descriptionBn   String            @db.Text
  
  // Category
  category        ClassifiedCategory @relation(fields: [categoryId], references: [id])
  categoryId      String
  
  // Price
  price           Float?
  currency        String            @default("BDT")
  priceNegotiable Boolean           @default(false)
  
  // Condition
  condition       ItemCondition?
  
  // Location
  city            String
  area            String?
  
  // Media
  images          String[]
  
  // Contact
  contactName     String
  contactPhone    String
  contactWhatsapp String?
  
  // Owner
  owner           User              @relation(fields: [ownerId], references: [id])
  ownerId         String
  
  // Status
  status          ListingStatus     @default(DRAFT)
  featured        Boolean           @default(false)
  sold            Boolean           @default(false)
  views           Int               @default(0)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  publishedAt     DateTime?
  expiresAt       DateTime?
  
  @@index([slug])
  @@index([ownerId])
  @@index([categoryId])
  @@index([status])
  @@map("classifieds")
}

model ClassifiedCategory {
  id          String       @id @default(cuid())
  name        String
  nameBn      String
  slug        String       @unique
  icon        String?
  order       Int          @default(0)
  
  classifieds Classified[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([slug])
  @@map("classified_categories")
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

// ==========================================
// CONTENT MANAGEMENT (NEWS, PAGES, BLOG)
// ==========================================

model Article {
  id              String        @id @default(cuid())
  title           String
  titleBn         String
  slug            String        @unique
  excerpt         String?       @db.Text
  excerptBn       String?       @db.Text
  content         String        @db.Text
  contentBn       String        @db.Text
  
  // Type
  type            ArticleType
  
  // Category
  category        ArticleCategory? @relation(fields: [categoryId], references: [id])
  categoryId      String?
  
  // Media
  featuredImage   String?
  images          String[]
  
  // Tags
  tags            String[]
  
  // SEO
  metaTitle       String?
  metaDescription String?
  
  // Author
  authorName      String?
  authorId        String?
  
  // Status & Visibility
  status          PostStatus    @default(DRAFT)
  featured        Boolean       @default(false)
  views           Int           @default(0)
  
  // Source (for news)
  source          String?
  sourceUrl       String?
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?
  
  @@index([slug])
  @@index([type])
  @@index([categoryId])
  @@index([status])
  @@map("articles")
}

enum ArticleType {
  NEWS
  BLOG
  ANNOUNCEMENT
  GUIDE
  PAGE
}

model ArticleCategory {
  id          String    @id @default(cuid())
  name        String
  nameBn      String
  slug        String    @unique
  type        ArticleType
  order       Int       @default(0)
  
  articles    Article[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([slug])
  @@map("article_categories")
}

// ==========================================
// EMERGENCY SERVICES
// ==========================================

model EmergencyContact {
  id          String   @id @default(cuid())
  name        String
  nameBn      String
  category    String
  phone       String
  alternatePhone String?
  description String?
  descriptionBn String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@map("emergency_contacts")
}

// ==========================================
// ADVERTISEMENTS
// ==========================================

model Advertisement {
  id          String        @id @default(cuid())
  title       String
  image       String
  link        String?
  position    String // "banner_top", "sidebar_right", etc.
  type        AdType
  
  // Targeting
  pages       String[] // ["home", "jobs", "property"]
  cities      String[]
  
  // Schedule
  startDate   DateTime
  endDate     DateTime
  
  // Status
  status      AdStatus      @default(PENDING)
  
  // Statistics
  impressions Int           @default(0)
  clicks      Int           @default(0)
  
  // Client
  clientName  String?
  clientEmail String?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([position])
  @@index([status])
  @@map("advertisements")
}

enum AdType {
  BANNER
  SIDEBAR
  INLINE
  POPUP
}

enum AdStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
}

// ==========================================
// ANALYTICS & TRACKING
// ==========================================

model PageView {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  userAgent   String?
  ipAddress   String?
  country     String?
  city        String?
  
  // User (optional, if logged in)
  userId      String?
  
  createdAt   DateTime @default(now())
  
  @@index([path])
  @@index([userId])
  @@index([createdAt])
  @@map("page_views")
}

// ==========================================
// SYSTEM CONFIGURATION
// ==========================================

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // string, number, boolean, json
  description String?
  group       String?  // "general", "email", "payment"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([key])
  @@index([group])
  @@map("settings")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  changes     Json?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
